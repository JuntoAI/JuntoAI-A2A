{
  "enabled": true,
  "name": "Backend Unit Tests on Save",
  "description": "Runs backend unit tests (pytest -m unit) whenever a Python file in backend/app/ is saved, providing instant feedback on regressions before commit.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "backend/app/**/*.py"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Run backend unit tests: cd backend && ../.venv/bin/python -m pytest -m unit -x -q --tb=short 2>&1 | tail -30. If any tests FAIL, clearly report which tests failed and why. If all pass, just say '✅ All unit tests pass' and nothing else."
  }
}
