# ============================================================
# JuntoAI A2A Local Battle Arena — Environment Configuration
# ============================================================
# No .env file is needed for a first run with Ollama.
# Just run: docker compose up
# Copy this file to .env and edit only what you need:
#   cp .env.example .env
# ============================================================

# --- Run Mode ------------------------------------------------
# cloud = GCP Firestore + Vertex AI + waitlist gate
# local = SQLite + LiteLLM + no auth gate (default)
RUN_MODE=local

# --- LLM Provider --------------------------------------------
# ollama   = local Ollama sidecar, no API key needed (default)
# openai   = OpenAI API (requires OPENAI_API_KEY)
# anthropic = Anthropic API (requires ANTHROPIC_API_KEY)
LLM_PROVIDER=ollama

# --- Ollama --------------------------------------------------
# Base URL for the Ollama API (Docker Compose internal default)
OLLAMA_BASE_URL=http://ollama:11434
# Model to pull and use for all agents
OLLAMA_MODEL=llama3.1

# --- OpenAI (uncomment if LLM_PROVIDER=openai) --------------
# OPENAI_API_KEY=sk-...

# --- Anthropic (uncomment if LLM_PROVIDER=anthropic) --------
# ANTHROPIC_API_KEY=sk-ant-...

# --- Model Overrides -----------------------------------------
# Force a single model for all agents (overrides all mappings)
# LLM_MODEL_OVERRIDE=gpt-4o-mini
# Per-model-id JSON overrides (takes precedence over defaults)
# MODEL_MAP={"gemini-2.5-flash": "gpt-4o-mini", "gemini-2.5-pro": "gpt-4o"}

# --- Database ------------------------------------------------
# SQLite file path (local mode only)
SQLITE_DB_PATH=data/juntoai.db

# --- Frontend ------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_RUN_MODE=local

# --- Cloud Mode (only needed when RUN_MODE=cloud) ------------
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# VERTEX_AI_LOCATION=europe-west1
